# ─── Environment Variables ────────────────────────────────────────────────────
# NEVER commit secrets to Git
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production

# .env.example files ARE committed — they are safe templates (no real secrets)
!.env.example
!backend/.env.example
!frontend/.env.example


