# Backend Environment Variables
# Copy this file to .env and fill in your values

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from Atlas → Connect → Drivers → copy the connection string
# Replace <password> with your DB user password and <dbname> with: goal-tracking-portal
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/goal-tracking-portal?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Vercel frontend URL after deploying.
# Example: https://goalsync-portal.vercel.app
# For multiple domains: https://app.vercel.app,https://custom-domain.com
ALLOWED_ORIGINS=https://your-frontend.vercel.app
