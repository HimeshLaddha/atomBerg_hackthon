# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All Vite env vars MUST start with VITE_ to be accessible in the browser.

# ── Backend API URL ───────────────────────────────────────────────────────────
# Development: point to your local backend
# VITE_API_URL=http://localhost:5000

# Production: set this to your Render backend URL in Vercel project settings
# Example: https://goalsync-api.onrender.com
VITE_API_URL=https://your-backend.onrender.com
